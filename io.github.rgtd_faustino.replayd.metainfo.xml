<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.rgtd_faustino.replayd</id>

  <name>replayd</name>
  <summary>Instant replay buffer for Wayland</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <description>
    <p>
      replayd runs a continuous recording buffer in the background and saves a
      clip on demand — similar to NVIDIA ShadowPlay or AMD ReLive, but for any
      Wayland compositor on Linux.
    </p>
    <p>Features:</p>
    <ul>
      <li>Configurable rolling buffer (seconds before and after trigger)</li>
      <li>Global shortcut via the XDG GlobalShortcuts portal</li>
      <li>Hardware-accelerated encoding: VA-API, NVENC, or software x264</li>
      <li>Separate game and microphone audio tracks with per-track mixer</li>
      <li>Clip viewer with trim and audio mix controls</li>
      <li>Output resolution and bitrate controls to manage file size</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.rgtd_faustino.replayd.desktop</launchable>

  <url type="homepage">https://github.com/rgtd-faustino/replayd</url>
  <url type="bugtracker">https://github.com/rgtd-faustino/replayd/issues</url>

  <developer id="io.github.rgtd_faustino">
    <name>rgtd-faustino</name>
  </developer>

  <provides>
    <binary>replayd</binary>
  </provides>

  <requires>
    <display_length compare="ge">768</display_length>
    <internet>offline-only</internet>
  </requires>

  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
  </recommends>

  <categories>
    <category>AudioVideo</category>
    <category>Video</category>
    <category>Recorder</category>
  </categories>

  <keywords>
    <keyword>replay</keyword>
    <keyword>recording</keyword>
    <keyword>capture</keyword>
    <keyword>wayland</keyword>
    <keyword>gaming</keyword>
    <keyword>clip</keyword>
    <keyword>buffer</keyword>
    <keyword>shadowplay</keyword>
  </keywords>

